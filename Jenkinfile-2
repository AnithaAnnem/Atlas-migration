pipeline {
    agent any

    triggers {
        githubPush()
    }

    options {
        timestamps()
    }

    environment {
        DB_URL = "postgres://postgres:postgres@localhost:5432/testdb?sslmode=disable"
        DEV_DB_URL = "postgres://postgres:postgres@localhost:5432/atlas_dev?sslmode=disable"
        MIGRATIONS_DIR = "file://migrations"
        SCHEMA_FILE = "file://schema.hcl"
        ATLAS_URL = "https://release.ariga.io/atlas/atlas-linux-amd64-latest"
    }

    stages {

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout Repository') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/AnithaAnnem/Atlas-migration.git'
            }
        }

        stage('Install PostgreSQL') {
            steps {
                sh '''
                    sudo apt update
                    sudo apt install -y postgresql postgresql-contrib
                '''
            }
        }

        stage('Start PostgreSQL') {
            steps {
                sh '''
                    sudo systemctl restart postgresql
                    sleep 5
                '''
            }
        }

        stage('Setup Databases') {
            steps {
                sh '''
                    sudo -u postgres psql -c "ALTER USER postgres WITH PASSWORD 'postgres';"

                    # main DB
                    sudo -u postgres psql -tc "SELECT 1 FROM pg_database WHERE datname='testdb'" | grep -q 1 || \
                    sudo -u postgres createdb testdb

                    # CLEAN dev DB for Atlas diff
                    sudo -u postgres psql -tc "SELECT 1 FROM pg_database WHERE datname='atlas_dev'" | grep -q 1 || \
                    sudo -u postgres createdb atlas_dev
                '''
            }
        }

        stage('Download Atlas CLI') {
            steps {
                sh '''
                    wget -q ${ATLAS_URL} -O atlas
                    chmod +x atlas
                    ./atlas version
                '''
            }
        }

        stage('Ensure Migration Hash') {
            steps {
                sh '''
                    mkdir -p migrations
                    ./atlas migrate hash --dir ${MIGRATIONS_DIR}
                '''
            }
        }

        stage('Generate Migration (FIXED)') {
            steps {
                sh '''
                    ./atlas migrate diff auto_schema_update \
                        --dir ${MIGRATIONS_DIR} \
                        --to ${SCHEMA_FILE} \
                        --dev-url "${DEV_DB_URL}"
                '''
            }
        }

        stage('Rehash Migrations') {
            steps {
                sh '''
                    ./atlas migrate hash --dir ${MIGRATIONS_DIR}
                '''
            }
        }

        stage('Apply Migrations') {
            steps {
                sh '''
                    ./atlas migrate apply \
                        --dir ${MIGRATIONS_DIR} \
                        --url "${DB_URL}"
                '''
            }
        }

        stage('Verify Schema Change') {
            steps {
                sh '''
                    PGPASSWORD=postgres psql \
                        -h localhost -U postgres -d testdb \
                        -c "\\d users"
                '''
            }
        }

        stage('Verify City Column') {
            steps {
                sh '''
                    PGPASSWORD=postgres psql \
                        -h localhost -U postgres -d testdb \
                        -c "SELECT column_name FROM information_schema.columns WHERE table_name='users';"
                '''
            }
        }
    }

    post {
        success {
            echo "Atlas Migration SUCCESS"
        }
        failure {
            echo "Atlas Migration FAILED"
        }
    }
}
